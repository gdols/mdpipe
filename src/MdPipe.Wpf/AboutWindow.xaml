<Window x:Class="MdPipe.Wpf.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About MdPipe"
        SizeToContent="Height" Width="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Background}"
        Icon="/Assets/icon.png"
        FontFamily="Segoe UI">

    <Border Margin="26" Background="{StaticResource Surface}" CornerRadius="14"
            BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="28">
        <StackPanel>
            <!-- App identity -->
            <StackPanel Orientation="Horizontal">
                <Image Source="/Assets/icon.png" Width="60" Height="60" Margin="0,0,16,0"
                       VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="26" FontWeight="Bold">
                        <Run Text="Md" Foreground="{StaticResource Accent}" /><Run Text="Pipe" Foreground="{StaticResource TextPrimary}" />
                    </TextBlock>
                    <TextBlock x:Name="VersionText" FontSize="12.5"
                               Foreground="{StaticResource TextMuted}" Margin="0,1,0,0" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Convert your documents to Markdown. Hassle-free."
                       FontSize="13.5" Foreground="{StaticResource TextMuted}"
                       TextWrapping="Wrap" Margin="0,14,0,0" />

            <Border Height="1" Background="{StaticResource Border}" Margin="0,20,0,18" />

            <!-- Author -->
            <TextBlock Text="DEVELOPED BY" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextMuted}" />
            <TextBlock Text="Guillermo Dols" FontSize="17" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimary}" Margin="0,4,0,14" />

            <!-- Contact / links -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Web" FontSize="13"
                           Foreground="{StaticResource TextMuted}" Margin="0,0,0,9" />
                <TextBlock Grid.Row="0" Grid.Column="1" FontSize="13" Margin="0,0,0,9">
                    <Hyperlink NavigateUri="https://gdols.dev"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{StaticResource Accent}">gdols.dev</Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Email" FontSize="13"
                           Foreground="{StaticResource TextMuted}" Margin="0,0,0,9" />
                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="13" Margin="0,0,0,9">
                    <Hyperlink NavigateUri="mailto:guille@gdols.dev"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{StaticResource Accent}">guille@gdols.dev</Hyperlink>
                </TextBlock>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Project" FontSize="13"
                           Foreground="{StaticResource TextMuted}" />
                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="13">
                    <Hyperlink NavigateUri="https://github.com/gdols/MdPipe"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{StaticResource Accent}">github.com/gdols/MdPipe</Hyperlink>
                </TextBlock>
            </Grid>

            <Border Height="1" Background="{StaticResource Border}" Margin="0,20,0,16" />

            <!-- Disclaimer -->
            <TextBlock FontSize="11.5" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap"
                       Text="MdPipe is an independent, unofficial project. It is not affiliated with or sponsored by Microsoft. It uses Microsoft MarkItDown (MIT license), which is downloaded from PyPI at runtime." />

            <Button Content="Close" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" Margin="0,18,0,0"
                    IsCancel="True" Click="Close_Click" />
        </StackPanel>
    </Border>
</Window>
